# ────────────────────────────────────────────
# 나무의사 MCP 서버 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값을 채우세요
# cp .env.example .env
# ────────────────────────────────────────────

# 1. 공공데이터포털 API 키 (무료 발급)
#    → https://www.data.go.kr 회원가입 후 마이페이지에서 발급
DATA_GO_KR_API_KEY=여기에_공공데이터포털_API키_입력

# 2. 카카오 API 키
#    → https://developers.kakao.com 에서 앱 생성 후 발급
KAKAO_REST_API_KEY=여기에_카카오_REST_API키_입력
KAKAO_MAP_API_KEY=여기에_카카오맵_API키_입력

# 3. Anthropic Claude API 키 (병해충 진단 AI)
#    → https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=여기에_Anthropic_API키_입력

# 4. 서버 설정 (클라우드 배포 시)
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 5. DB 설정
#    로컬 테스트용: sqlite:///./tree_doctor.db (기본값, 별도 설치 불필요)
#    클라우드(AWS RDS 등): postgresql://user:password@host:5432/tree_doctor
DATABASE_URL=sqlite:///./tree_doctor.db
